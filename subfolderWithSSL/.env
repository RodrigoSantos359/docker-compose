N8N_VERSION=stable

# Pasta onde os dados devem ser salvos
DATA_FOLDER=/root/n8n/

# Domínio de nível superior a partir do qual servir os dados
DOMAIN_NAME=example.com

# Subpasta a partir da qual servir os dados
SUBFOLDER=app1
N8N_PATH=/app1/

# O nome do domínio e o subdomínio combinados determinam de onde o n8n será acessível
# O exemplo acima resultaria em: https://example.com/app1/

# Fuso horário opcional a ser definido, que será usado pelo Cron-Node por padrão
# Se não for definido, o horário de Nova York será usado
GENERIC_TIMEZONE=Europe/Berlin

# Endereço de e-mail a ser usado para a criação do certificado SSL
SSL_EMAIL=user@example.com

RUNNERS_AUTH_TOKEN=changeRunnerAuthToken